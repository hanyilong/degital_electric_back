<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.device.manage.mapper.MenuMapper">
  <resultMap id="BaseResultMap" type="com.device.manage.entity.Menu">
    <id column="id" property="id"/>
    <result column="name" property="name"/>
    <result column="key" property="key"/>
    <result column="path" property="path"/>
    <result column="icon" property="icon"/>
    <result column="parent_id" property="parentId"/>
  </resultMap>

  <select id="selectAll" resultMap="BaseResultMap"><![CDATA[SELECT * FROM menu order by sort_order]]></select>

  <select id="selectById" parameterType="long" resultMap="BaseResultMap"><![CDATA[SELECT * FROM menu WHERE id = #{id}]]></select>

  <select id="selectByParentId" parameterType="long" resultMap="BaseResultMap"><![CDATA[SELECT * FROM menu WHERE parent_id = #{parentId}]]></select>

  <select id="selectByProjectId" parameterType="long" resultMap="BaseResultMap">
    <![CDATA[
      SELECT m.* FROM menu m
      INNER JOIN project_menu pm ON m.id = pm.menu_id
      WHERE pm.project_id = #{projectId}
    ]]>
  </select>

  <select id="selectByUserId" parameterType="long" resultMap="BaseResultMap">
    <![CDATA[
      SELECT m.* FROM menu m
      INNER JOIN project_menu pm ON m.id = pm.menu_id
      INNER JOIN user u ON pm.project_id = u.project_id
      WHERE u.id = #{userId}
    ]]>
  </select>

  <insert id="insert" parameterType="com.device.manage.entity.Menu">
    <![CDATA[
      INSERT INTO menu (name, key, path, icon, parent_id)
      VALUES (#{name}, #{key}, #{path}, #{icon}, #{parentId})
    ]]>
  </insert>

  <update id="update" parameterType="com.device.manage.entity.Menu">
    <![CDATA[
      UPDATE menu
      SET name = #{name}, key = #{key}, path = #{path}, icon = #{icon}, parent_id = #{parentId}
      WHERE id = #{id}
    ]]>
  </update>

  <delete id="delete" parameterType="long"><![CDATA[DELETE FROM menu WHERE id = #{id}]]></delete>
</mapper>
