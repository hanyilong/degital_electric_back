<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.device.manage.mapper.UserMapper">
  <resultMap id="BaseResultMap" type="com.device.manage.entity.User">
    <id column="id" property="id"/>
    <result column="username" property="username"/>
    <result column="password" property="password"/>
    <result column="project_id" property="projectId"/>
    <result column="role" property="role"/>
    <result column="status" property="status"/>
    <result column="create_time" property="createTime"/>
    <result column="update_time" property="updateTime"/>
  </resultMap>
  <select id="selectAll" resultMap="BaseResultMap"><![CDATA[SELECT * FROM user]]></select>
  <select id="selectById" parameterType="long" resultMap="BaseResultMap"><![CDATA[SELECT * FROM user WHERE id = #{id}]]></select>
  <select id="selectByUsername" parameterType="string" resultMap="BaseResultMap"><![CDATA[SELECT * FROM user WHERE username = #{username}]]></select>
  <select id="selectByUsernameAndPassword" resultMap="BaseResultMap">
    <![CDATA[SELECT * FROM user WHERE username = #{username} AND password = #{password}]]>
  </select>
  <select id="selectByUsernameAndPasswordAndProjectId" resultMap="BaseResultMap">
    <![CDATA[SELECT * FROM user WHERE username = #{username} AND password = #{password} AND project_id = #{projectId}]]>
  </select>
  <insert id="insert" parameterType="com.device.manage.entity.User"><![CDATA[INSERT INTO user (username, password, project_id, role, status, create_time, update_time) VALUES (#{username}, #{password}, #{projectId}, #{role}, #{status}, NOW(), NOW())]]></insert>
  <update id="update" parameterType="com.device.manage.entity.User"><![CDATA[UPDATE user SET username = #{username}, password = #{password}, project_id = #{projectId}, role = #{role}, status = #{status}, update_time = NOW() WHERE id = #{id}]]></update>
  <delete id="deleteById" parameterType="long"><![CDATA[DELETE FROM user WHERE id = #{id}]]></delete>
</mapper>